#.env.example

# ----- App -----
PORT=4001
NODE_ENV=development

# ----- Redis -----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_strong_redis_password_here

# ----- Redis Events Channels -----
REDIS_CHANNEL_FILE_UPLOADED=file:uploaded
REDIS_CHANNEL_FILE_DOWNLOADED=file:downloaded
REDIS_CHANNEL_FILE_DELETED=file:deleted

# ----- API Key Authentication -----
API_KEY_REQUIRED=false  # true in production | false in development
API_KEYS=app_key_core_nestjs,app_key_python_backend,app_key_nextjs

# ----- CORS -----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ----- Storage Configuration -----
STORAGE_ADAPTER=local  # local | s3 | cloudinary
STORAGE_LOCAL_BASE_PATH=./uploads

# ----- File Restrictions (Global Defaults) -----
MAX_FILE_SIZE_MB=50
MAX_UPLOAD_FILES=10
ALLOWED_MIME_TYPES=*  # * = all | application/pdf,image/*,video/*

# ----- S3 (Optional - for Phase 2) -----
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=your_bucket

# ----- Cloudinary (Optional - for Phase 3) -----
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret