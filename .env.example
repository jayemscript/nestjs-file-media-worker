#.env.example

# ----- App -----
PORT=4001
NODE_ENV=development

# ----- Redis -----
# Local (Docker):   redis://localhost:6379
# Local with auth:  redis://:your_password@127.0.0.1:6379
# Upstash:          rediss://<user>:<pass>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ----- Redis Auth (production docker-compose only) -----
REDIS_PASSWORD=your_strong_redis_password_here
# ----- Redis Events -----
REDIS_CHANNEL_FILE_UPLOADED=file:uploaded
REDIS_CHANNEL_FILE_DOWNLOADED=file:downloaded
REDIS_CHANNEL_FILE_DELETED=file:deleted

API_KEY=your_api_key_here
CORS_ORIGINS=http://localhost:3001,http://localhost:8081


# ----- Cookie -----
# Cookie secret - used to sign cookies
COOKIE_SECRET=your_cookie_secret_here
# lax = web (Next.js) | none = cross-site (requires HTTPS) | strict = same-site only
# Note: React Native authenticates via Authorization header, not cookies
COOKIE_SAMESITE=lax
# Expiration in milliseconds: 86400000 = 1 day | 604800000 = 7 days | 2592000000 = 30 days
COOKIE_EXPIRATION=86400000

# ----- API Keys -----
# Comma-separated keys - one per connected app
# Used in X-API-KEY request header from any app calling this service
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=app_key_your_core_nestjs_app,app_key_another_app

# ----- Storage Configuration -----
STORAGE_ADAPTER=local  # local | s3 | cloudinary
STORAGE_LOCAL_BASE_PATH=./uploads

# ----- File Restrictions (Global Defaults) -----
MAX_FILE_SIZE_MB=50
MAX_UPLOAD_FILES=10
ALLOWED_MIME_TYPES=*  # * = all | application/pdf,image/*,video/*

