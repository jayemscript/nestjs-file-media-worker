# Application
NODE_ENV=development
PORT=7007
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# MongoDB metadata (required)
# Atlas example: mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=file_media_service

# Test database. The test database name must end in _test.
# MONGO_TEST_URI falls back to MONGO_URI when omitted.
MONGO_TEST_URI=mongodb://localhost:27017
MONGO_TEST_DB_NAME=file_media_service_test

# Phase 1 storage (required while STORAGE_PROVIDER=local)
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./upload

# Multipart and application validation
MAX_FILE_SIZE_BYTES=10485760
MAX_BULK_FILE_COUNT=10
MAX_BULK_TOTAL_SIZE_BYTES=52428800
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,audio/mpeg,audio/wav,video/mp4,video/webm

# Required for DELETE /files/:fileId/permanent. Use a long random secret.
HARD_DELETE_ADMIN_KEY=replace-with-a-long-random-secret

# Phase 2 S3 configuration (inactive and not validated in Phase 1)
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_BUCKET=replace-me
